# Copy to .env in the project root for local backend development.

DATABASE_URL=sqlite:///./fixhire.db
JWT_SECRET_KEY=change_me_to_a_long_random_string
GEMINI_API_KEY=
GEMINI_MODEL_NAME=gemini-2.5-flash

# Google OAuth (optional locally; required for Google sign-in in production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:8000/api/auth/google/callback
FRONTEND_URL=http://localhost:5173

# --- Production-only (set in hosting dashboards, not committed) ---
# Render backend: DATABASE_URL=postgresql://... from Neon
# Render backend: FRONTEND_URL=https://your-app.vercel.app
# Render backend: GOOGLE_OAUTH_REDIRECT_URI=https://your-api.onrender.com/api/auth/google/callback
# Vercel frontend: VITE_API_URL=https://your-api.onrender.com
